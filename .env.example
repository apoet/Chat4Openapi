# SQLite database used by the single Chat4Openapi application instance.
CHAT4OPENAPI_DATABASE_URL=sqlite:///data/chat4openapi.db

# Supported values: en-US, zh-CN. English is the product default.
CHAT4OPENAPI_DEFAULT_LOCALE=en-US

# Set true only when Chat4Openapi is served through HTTPS.
CHAT4OPENAPI_SECURE_COOKIES=false

CHAT4OPENAPI_ADMIN_SESSION_IDLE_MINUTES=30
CHAT4OPENAPI_ADMIN_SESSION_ABSOLUTE_HOURS=8
