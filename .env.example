# Docker Compose image and published port. `docker compose push` publishes the
# resulting tag to Docker Hub.
DOCKERHUB_USERNAME=apoet2003
AGENT4API_TAG=latest
AGENT4API_PORT=8000

# SQLite database used by the single Agent4API application instance.
CHAT4OPENAPI_DATABASE_URL=sqlite:///data/chat4openapi.db

# Supported values: en-US, zh-CN. English is the product default.
CHAT4OPENAPI_DEFAULT_LOCALE=en-US

# Set true only when Agent4API is served through HTTPS.
CHAT4OPENAPI_SECURE_COOKIES=false

CHAT4OPENAPI_ADMIN_SESSION_IDLE_MINUTES=30
CHAT4OPENAPI_ADMIN_SESSION_ABSOLUTE_HOURS=8
CHAT4OPENAPI_BROWSER_CHAT_SESSION_DAYS=30

# Administrator password recovery writes a one-time key to this private,
# server-only directory. The key expires after the configured number of minutes.
CHAT4OPENAPI_ADMIN_PASSWORD_RESET_DIR=data/password-reset
CHAT4OPENAPI_ADMIN_PASSWORD_RESET_MINUTES=15

# By default a Fernet key is created once at data/.chat4openapi.key.
# Back up this file with the SQLite database. For managed secret injection, set
# CHAT4OPENAPI_ENCRYPTION_KEY to a stable Fernet key instead. Never rotate either
# value without re-encrypting stored secrets.
# CHAT4OPENAPI_ENCRYPTION_KEY=
CHAT4OPENAPI_ENCRYPTION_KEY_FILE=data/.chat4openapi.key
