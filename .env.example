# SQLite database used by the single ChatAPI application instance.
CHATAPI_DATABASE_URL=sqlite:///data/chatapi.db

# Supported values: en-US, zh-CN. English is the product default.
CHATAPI_DEFAULT_LOCALE=en-US

# Set true only when ChatAPI is served through HTTPS.
CHATAPI_SECURE_COOKIES=false

CHATAPI_ADMIN_SESSION_IDLE_MINUTES=30
CHATAPI_ADMIN_SESSION_ABSOLUTE_HOURS=8
